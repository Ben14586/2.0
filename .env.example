HOST=0.0.0.0
PORT=3000
DATABASE_FILE=database.db
UPLOADS_DIR=uploads

# Cloud Services (For Production / Scaling)
# DATABASE_URL=postgresql://user:password@host:port/dbname
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Public URLs used when the static site talks to the online backend.
# Example:
# PUBLIC_SITE_URL=https://game-services-hwcy.onrender.com
# ADMIN_SITE_URL=https://game-services-hwcy.onrender.com
# PUBLIC_API_BASE_URL=https://your-backend.onrender.com
PUBLIC_SITE_URL=https://game-services-hwcy.onrender.com
ADMIN_SITE_URL=https://game-services-hwcy.onrender.com
PUBLIC_API_BASE_URL=https://game-services-hwcy.onrender.com
ALLOWED_ORIGINS=https://game-services-hwcy.onrender.com

# Set this before first deploy. Existing SQLite admins keep their current password until changed.
ADMIN_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-this-before-first-run
ADMIN_SESSION_HOURS=8

# Optional master key for emergency API access. Leave blank to disable.
# Generate local values with: npm run tokens:setup
ADMIN_KEY=

# Optional notification channels.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LINE_NOTIFY_TOKEN=

# Upload/body limits in bytes.
MAX_JSON_BODY_BYTES=5242880
MAX_SLIP_BYTES=3145728

# Set to 1 only behind HTTPS.
COOKIE_SECURE=0
COOKIE_SAMESITE=Strict

# Set to 1 for local testing by opening HTML directly from file://.
ALLOW_FILE_ORIGIN=1
