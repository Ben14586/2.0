HOST=0.0.0.0
DATABASE_FILE=/var/data/database.db
UPLOADS_DIR=/var/data/uploads

# Cloud Services (Recommended for Production)
# DATABASE_URL=postgresql://user:password@host:port/dbname
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

ADMIN_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
ADMIN_SESSION_HOURS=8
# Optional emergency key. Generate privately with: python tools/manage_tokens.py --write-env --rotate-admin-key --print-values
ADMIN_KEY=

PUBLIC_SITE_URL=https://store-game-0.netlify.app
ADMIN_SITE_URL=https://store-game-0.netlify.app
PUBLIC_API_BASE_URL=https://your-backend-host.example.com
ALLOWED_ORIGINS=https://store-game-0.netlify.app

COOKIE_SECURE=1
COOKIE_SAMESITE=None
ALLOW_FILE_ORIGIN=0

MAX_JSON_BODY_BYTES=5242880
MAX_SLIP_BYTES=3145728
MAX_GAME_IMAGE_BYTES=4194304

TELEGRAM_BOT_TOKEN=
