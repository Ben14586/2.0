{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false
  },
  "include": ["components/**/*.ts", "components/**/*.tsx", "frontend/**/*.ts", "frontend/**/*.tsx", "lib/**/*.ts", "vite.config.ts"]
}
